<input
    class="{{className}}"
    {{#if id}}id="{{id}}"{{/if}}
    type="{{type}}"
    {{#if name}}name="{{name}}"{{/if}}
    {{#if value}}value="{{value}}"{{/if}}
    {{#if placeholder}}placeholder="{{placeholder}}"{{/if}}
    {{#if accept}}accept="{{accept}}"{{/if}}
    {{#if autocomplete}}autocomplete="{{autocomplete}}"{{/if}}
    {{#if minlength}}minlength="{{minlength}}"{{/if}}
    {{#if maxlength}}maxlength="{{maxlength}}"{{/if}}
    {{#if validationRule}}data-validation-rule="{{validationRule}}"{{/if}}
    {{#if isInvalid}}aria-invalid="true"{{/if}}
    {{#if isInvalid}}{{#if describedBy}}aria-describedby="{{describedBy}}"{{/if}}{{/if}}
    {{#if required}}required{{/if}}
    {{#if disabled}}disabled{{/if}}
    {{#if readonly}}readonly{{/if}}
/>

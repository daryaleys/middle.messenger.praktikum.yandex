<main class="profile-page">
    <aside class="profile-page__navigation" aria-label="Навигация профиля">
        <a class="profile-page__back-link" href="/" aria-label="Вернуться к чатам">
            <svg class="profile-page__back-icon" viewBox="0 0 28 28" aria-hidden="true">
                <path d="M20 13H10.8l3.6-3.6L13 8l-6 6 6 6 1.4-1.4-3.6-3.6H20v-2z" />
            </svg>
        </a>
    </aside>

    <section class="profile" aria-labelledby="profile-title">
        <div class="profile__content">
            {{{ProfileAvatar}}}

            <h1 class="profile__title" id="profile-title">{{profileData.firstName}}</h1>

            {{#if isDataEditMode}}
                {{{ProfileEditForm fields=profileData.mainFields}}}
            {{else if isPasswordEditMode}}
                {{{ProfileEditForm fields=profileData.passwordFields}}}
            {{else}}
                {{{ProfileDetails profileData=profileData}}}
                {{{ProfileActions}}}
            {{/if}}
        </div>
    </section>
</main>

{{#with activeChat}}
  <section class="dialog" aria-label="Открытый диалог">
    <header class="dialog-header">
      <span class="dialog-header__avatar" aria-hidden="true"></span>
      <h1 class="dialog-header__title">{{title}}</h1>
      <button class="dialog-header__menu" type="button" aria-label="Открыть меню диалога">
        <svg class="dialog-header__menu-icon" viewBox="0 0 128 512" aria-hidden="true">
          <path d="M64 360a56 56 0 1 0 0 112 56 56 0 1 0 0-112zm0-160a56 56 0 1 0 0 112 56 56 0 1 0 0-112zM120 96A56 56 0 1 0 8 96a56 56 0 1 0 112 0z" />
        </svg>
      </button>
    </header>

    <div class="dialog-messages">
      <time class="dialog-date">{{date}}</time>

      {{#each messages}}
        <article class="message {{#if isOwn}}message--own{{/if}}">
          {{#if text}}
            <p class="message__text">{{text}}</p>
          {{/if}}

          {{#if imageUrl}}
            <img class="message__image" src="{{imageUrl}}" alt="{{imageAlt}}" />
          {{/if}}

          <time class="message__time">{{time}}</time>
        </article>
      {{/each}}
    </div>

    <form class="message-form {{#if (fieldError ../formErrors "message")}}message-form--error{{/if}}" action="#" method="post" novalidate>
      <button class="message-form__attach" type="button" aria-label="Прикрепить файл">
        <svg class="message-form__icon" viewBox="0 0 448 512" aria-hidden="true">
          <path d="M364.2 83.8c-24.4-24.4-64-24.4-88.4 0l-184 184c-42.1 42.1-42.1 110.3 0 152.4s110.3 42.1 152.4 0l152-152c10.9-10.9 28.7-10.9 39.6 0s10.9 28.7 0 39.6l-152 152c-64 64-167.6 64-231.6 0s-64-167.6 0-231.6l184-184c46.3-46.3 121.3-46.3 167.6 0s46.3 121.3 0 167.6l-176 176c-28.6 28.6-75 28.6-103.6 0s-28.6-75 0-103.6l144-144c10.9-10.9 28.7-10.9 39.6 0s10.9 28.7 0 39.6l-144 144c-6.7 6.7-6.7 17.7 0 24.4s17.7 6.7 24.4 0l176-176c24.4-24.4 24.4-64 0-88.4z" />
        </svg>
      </button>

      <label class="message-form__label" for="message-text">Сообщение</label>
      <input
        class="message-form__input"
        id="message-text"
        type="text"
        name="message"
        value="{{fieldValue ../formValues "message"}}"
        placeholder="Сообщение"
        {{#if (fieldError ../formErrors "message")}}aria-invalid="true" aria-describedby="message-text-error"{{/if}}
      />
      {{#if (fieldError ../formErrors "message")}}
        <span class="message-form__error" id="message-text-error">{{fieldError ../formErrors "message"}}</span>
      {{/if}}

      <button class="message-form__send" type="submit" aria-label="Отправить сообщение">
        <svg class="message-form__icon" viewBox="0 0 448 512" aria-hidden="true">
          <path d="M438.6 278.6c12.5-12.5 12.5-32.8 0-45.3l-160-160c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L338.8 224 32 224c-17.7 0-32 14.3-32 32s14.3 32 32 32l306.7 0L233.4 393.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l160-160z" />
        </svg>
      </button>
    </form>
  </section>
{{else}}
  <section class="dialog-empty" aria-label="Диалог">
    <p class="dialog-empty__text">Выберите чат, чтобы отправить сообщение</p>
  </section>
{{/with}}
